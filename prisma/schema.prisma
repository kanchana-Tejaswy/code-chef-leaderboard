datasource db {
  provider = "sqlite"
}

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

enum Role {
  STUDENT
  FACULTY
  PLACEMENT_OFFICER
  PRINCIPAL
  ADMIN
}

enum SyncStatus {
  SUCCESS
  FAILURE
}

enum SyncInitiatedBy {
  SYSTEM_CRON
  USER_MANUAL
  ADMIN_FORCE
}

model StudentProfile {
  id                String            @id @default(uuid())
  name              String
  rollNumber        String?           @unique @map("roll_number")
  department        String?
  year              Int?
  branch            String?
  section           String?
  profilePictureUrl String?           @map("profile_picture_url")
  codechefUsername  String?           @unique @map("codechef_username")
  leetcodeUsername  String?           @unique @map("leetcode_username")
  githubUsername    String?           @unique @map("github_username")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  
  codechefProfile  CodechefProfile?
  leetcodeProfile  LeetcodeProfile?
  githubProfile    GithubProfile?
  aiAnalysis       AiAnalysis?
  leaderboardEntry LeaderboardEntry?
  syncLogs         SyncLog[]
  activityLogs     ActivityLog[]

  @@map("student_profiles")
}

model CodechefProfile {
  id                     String         @id @default(uuid())
  studentId              String         @unique @map("student_id")
  student                StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  username               String         @unique
  fullName               String?        @map("full_name")
  country                String?
  institution            String?
  city                   String?
  currentRating          Int            @default(0) @map("current_rating")
  highestRating          Int            @default(0) @map("highest_rating")
  stars                  Int            @default(1)
  maxStars               Int?           @map("max_stars")
  globalRank             Int?           @map("global_rank")
  countryRank            Int?           @map("country_rank")
  problemsSolved         Int            @default(0) @map("problems_solved")
  fullySolvedCount       Int            @default(0) @map("fully_solved_count")
  partiallySolvedCount   Int            @default(0) @map("partially_solved_count")
  easySolvedCount        Int            @default(0) @map("easy_solved_count")
  mediumSolvedCount      Int            @default(0) @map("medium_solved_count")
  hardSolvedCount        Int            @default(0) @map("hard_solved_count")
  challengeSolvedCount   Int            @default(0) @map("challenge_solved_count")
  contestCount           Int            @default(0) @map("contest_count")
  longChallengeCount     Int            @default(0) @map("long_challenge_count")
  cookOffCount           Int            @default(0) @map("cook_off_count")
  lunchtimeCount         Int            @default(0) @map("lunchtime_count")
  startersCount          Int            @default(0) @map("starters_count")
  division               String?
  bestContestRank        Int?           @map("best_contest_rank")
  averageContestRank     Float?         @map("average_contest_rank")
  lastActive             DateTime?      @map("last_active")
  activeDaysCount        Int            @default(0) @map("active_days_count")
  ratingHistory          Json?          @map("rating_history")
  contestHistory         Json?          @map("contest_history")
  difficultyDistribution Json?          @map("difficulty_distribution")
  activitySummary        Json?          @map("activity_summary")
  statisticDetails       Json?          @map("statistic_details")
  contests               Json?          // Backward compatibility
  lastFetchedAt          DateTime       @default(now()) @map("last_fetched_at")
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")

  @@map("codechef_profiles")
}

model LeetcodeProfile {
  id                     String         @id @default(uuid())
  studentId              String         @unique @map("student_id")
  student                StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  username               String         @unique
  problemsSolved         Int            @default(0) @map("problems_solved")
  easySolvedCount        Int            @default(0) @map("easy_solved_count")
  mediumSolvedCount      Int            @default(0) @map("medium_solved_count")
  hardSolvedCount        Int            @default(0) @map("hard_solved_count")
  contestRating          Float          @default(0) @map("contest_rating")
  contestRank            Int            @default(0) @map("contest_rank")
  acceptanceRate         Float          @default(0) @map("acceptance_rate")
  heatmap                Json?          // Calendar heatmap style data
  weeklyActivity         Json?          // Weekly activity details
  skillRadar             Json?          // Skill radar chart values
  tagDistribution        Json?          // Tag distribution pie chart values
  consistencyScore       Float          @default(0) @map("consistency_score")
  ratingHistory          Json?          @map("rating_history")
  contestHistory         Json?          @map("contest_history")
  lastFetchedAt          DateTime       @default(now()) @map("last_fetched_at")
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")

  @@map("leetcode_profiles")
}

model GithubProfile {
  id                String         @id @default(uuid())
  studentId         String         @unique @map("student_id")
  student           StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  username          String         @unique
  totalRepositories Int            @default(0) @map("total_repositories")
  totalStars        Int            @default(0) @map("total_stars")
  totalForks        Int            @default(0) @map("total_forks")
  followers         Int            @default(0)
  contributions     Json?          // Contributions graph data
  languages         Json?          // Language distribution pie chart
  repos             Json?          // Top repositories list (clickable)
  commitTimeline    Json?          // Commit timeline data
  openSourceScore   Float          @default(0) @map("open_source_score")
  repoQualityScore  Json?          @map("repo_quality_score") // Repository quality score radar data
  lastFetchedAt     DateTime       @default(now()) @map("last_fetched_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  @@map("github_profiles")
}

model AiAnalysis {
  id                          String         @id @default(uuid())
  studentId                   String         @unique @map("student_id")
  student                     StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  talentScore                 Float          @default(0) @map("talent_score")
  consistencyScore            Float          @default(0) @map("consistency_score")
  problemSolvingScore         Float          @default(0) @map("problem_solving_score")
  competitiveProgrammingScore Float          @default(0) @map("competitive_programming_score")
  contestScore                Float          @default(0) @map("contest_score")
  learningScore               Float          @default(0) @map("learning_score")
  growthScore                 Float          @default(0) @map("growth_score")
  disciplineScore             Float          @default(0) @map("discipline_score")
  overallPotential            String?        @map("overall_potential")
  placementReadiness          String?        @map("placement_readiness")
  expectedRating6Months       Int?           @map("expected_rating_6_months")
  strengths                   Json?          // String array
  weaknesses                  Json?          // String array
  improvementAreas            Json?          @map("improvement_areas") // String array
  careerRecommendation        String?        @map("career_recommendation")
  suggestedCompanies          Json?          @map("suggested_companies") // String array
  recommendedLearningPath     Json?          @map("recommended_learning_path") // String array
  recommendations             Json?          // Backward compatibility
  careerSuggestions           Json?          // Backward compatibility
  generatedAt                 DateTime       @default(now()) @map("generated_at")
  createdAt                   DateTime       @default(now()) @map("created_at")
  updatedAt                   DateTime       @updatedAt @map("updated_at")

  @@map("ai_analysis")
}

model LeaderboardEntry {
  id             String         @id @default(uuid())
  studentId      String         @unique @map("student_id")
  student        StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  rank           Int            @default(0)
  rating         Int            @default(0)
  stars          Int            @default(1)
  talentScore    Float          @default(0) @map("talent_score")
  overallScore   Float          @default(0) @map("overall_score")
  codechefScore  Float          @default(0) @map("codechef_score")
  leetcodeScore  Float          @default(0) @map("leetcode_score")
  githubScore    Float          @default(0) @map("github_score")
  trendDirection String         @default("UP") @map("trend_direction")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@index([rank])
  @@index([talentScore(sort: Desc)])
  @@index([overallScore(sort: Desc)])
  @@map("leaderboard_entries")
}

model SyncLog {
  id           String          @id @default(uuid())
  studentId    String          @map("student_id")
  student      StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status       SyncStatus
  errorMessage String?         @map("error_message")
  initiatedBy  SyncInitiatedBy @map("initiated_by")
  durationMs   Int             @map("duration_ms")
  createdAt    DateTime        @default(now()) @map("created_at")

  @@map("sync_logs")
}

model ActivityLog {
  id        String          @id @default(uuid())
  eventType String          @map("event_type")
  studentId String?         @map("student_id")
  student   StudentProfile? @relation(fields: [studentId], references: [id], onDelete: Cascade)
  message   String
  createdAt DateTime        @default(now()) @map("created_at")

  @@map("activity_logs")
}
